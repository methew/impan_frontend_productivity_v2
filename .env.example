# ============================================
# IMPAN Productivity Frontend - Environment Config
# ============================================

# Backend API Configuration
# Default: Django backend running locally
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Development Server Port
# Change this if port 3003 is already in use
PORT=3003

# Browser Auto-open
# Set to 'none' to disable automatic browser opening on dev server start
# BROWSER=none
